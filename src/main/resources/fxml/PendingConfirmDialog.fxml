<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.budgettracker.ui.controller.PendingConfirmController"
      spacing="14" style="-fx-padding: 24; -fx-background-color: #f5f5f5;">

    <Label text="Confirm Pending Transactions"
           style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <Label text="Select a transaction below and confirm or cancel it:"/>

    <TableView fx:id="pendingTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="colDate"   text="Date"        prefWidth="100"/>
            <TableColumn fx:id="colDesc"   text="Description" prefWidth="180"/>
            <TableColumn fx:id="colAmount" text="Template Amt" prefWidth="120"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Actual Amount:"/>
        <TextField fx:id="actualAmountField" promptText="e.g. 14800.00" prefWidth="160"/>
    </HBox>

    <Label fx:id="statusLabel" styleClass="error-label" wrapText="true"/>

    <HBox spacing="8">
        <Button text="Confirm"        onAction="#onConfirm"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 20;"/>
        <Button text="Cancel Tx"      onAction="#onCancelTx"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 20;"/>
        <Button text="Close"          onAction="#onClose"
                style="-fx-padding: 8 20;"/>
    </HBox>
</VBox>
