<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.budgettracker.ui.controller.DashboardController"
            stylesheets="@../css/app.css">
    <left>
        <VBox styleClass="nav-sidebar" spacing="4" minWidth="200">
            <Label text="BudgetTracker" styleClass="nav-brand"/>
            <Button text="Home"         onAction="#showHome"         styleClass="nav-button" fx:id="btnHome"/>
            <Button text="Accounts"     onAction="#showAccounts"     styleClass="nav-button" fx:id="btnAccounts"/>
            <Button text="Transactions" onAction="#showTransactions"  styleClass="nav-button" fx:id="btnTransactions"/>
            <Button text="Budgets"      onAction="#showBudgets"      styleClass="nav-button" fx:id="btnBudgets"/>
            <Button text="Recurring"    onAction="#showRecurring"    styleClass="nav-button" fx:id="btnRecurring"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="themeToggleBtn" text="☀ Light Mode" onAction="#onToggleTheme" styleClass="theme-toggle-btn"/>
            <Label fx:id="userLabel" styleClass="nav-user"/>
            <Button text="Logout" onAction="#onLogout" styleClass="nav-button"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>
</BorderPane>
