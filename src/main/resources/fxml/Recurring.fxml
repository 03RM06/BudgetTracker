<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.budgettracker.ui.controller.RecurringController"
      spacing="16" styleClass="view-root">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Recurring Rules" styleClass="section-header" HBox.hgrow="ALWAYS"/>
        <Button fx:id="confirmPendingBtn" text="Confirm Pending" onAction="#onConfirmPending"
                managed="false" visible="false"
                styleClass="btn-warning"/>
        <Button text="Enable/Disable" onAction="#onToggleActive"
                styleClass="btn-secondary"/>
        <Button text="+ Add Rule" onAction="#onAddRule"
                styleClass="btn-primary"/>
    </HBox>

    <Label fx:id="statusLabel" styleClass="error-label"/>

    <TableView fx:id="ruleTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
            <TableColumn fx:id="colFrequency"   text="Frequency"   prefWidth="110"/>
            <TableColumn fx:id="colNextRun"     text="Next Run"    prefWidth="120"/>
            <TableColumn fx:id="colZone"        text="Zone"        prefWidth="140"/>
            <TableColumn fx:id="colActive"      text="Active"      prefWidth="80"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
</VBox>
