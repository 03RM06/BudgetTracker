<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.budgettracker.ui.controller.TransactionDialogController"
      spacing="10" styleClass="dialog-container">

    <Label fx:id="titleLabel" text="Add Transaction"
           styleClass="dialog-title"/>

    <Label text="Amount"/>
    <TextField fx:id="amountField" promptText="e.g. 500.00"/>

    <Label text="Description"/>
    <TextField fx:id="descriptionField" promptText="Optional description"/>

    <Label text="Date"/>
    <DatePicker fx:id="datePicker"/>

    <Label text="Direction"/>
    <ChoiceBox fx:id="directionChoice" prefWidth="200" onAction="#onDirectionChanged"/>

    <Label text="Account"/>
    <ChoiceBox fx:id="accountChoice" prefWidth="200"/>

    <Label fx:id="categoryLabel" text="Category (expense)"/>
    <ChoiceBox fx:id="categoryChoice" prefWidth="200"/>

    <Label fx:id="transferLabel" text="Transfer To Account" managed="false" visible="false"/>
    <ChoiceBox fx:id="transferAccountChoice" prefWidth="200" managed="false" visible="false"/>

    <Label fx:id="exchangeRateLabel" text="Exchange Rate" managed="false" visible="false"/>
    <TextField fx:id="exchangeRateField" promptText="e.g. 56.50" managed="false" visible="false"/>

    <Label fx:id="incomeNatureLabel" text="Income Nature"/>
    <ChoiceBox fx:id="incomeNatureChoice" prefWidth="200"/>

    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancel" styleClass="btn-secondary"/>
        <Button text="Save" onAction="#onSave"
                styleClass="btn-primary"/>
    </HBox>
</VBox>
