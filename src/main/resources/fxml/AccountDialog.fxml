<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.budgettracker.ui.controller.AccountDialogController"
      spacing="12" styleClass="dialog-container">

    <Label text="New Account" styleClass="dialog-title"/>

    <Label text="Name"/>
    <TextField fx:id="nameField" promptText="e.g. BDO Savings"/>

    <Label text="Currency (3-letter ISO code)"/>
    <TextField fx:id="currencyField" promptText="e.g. PHP"/>

    <Label text="Account Type"/>
    <ChoiceBox fx:id="typeChoice"/>

    <Label text="Opening Balance"/>
    <TextField fx:id="balanceField" promptText="e.g. 10000.00"/>

    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancel"
                styleClass="btn-secondary"/>
        <Button text="Create" onAction="#onCreate"
                styleClass="btn-primary"/>
    </HBox>
</VBox>
