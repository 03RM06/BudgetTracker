<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.budgettracker.ui.controller.BudgetDialogController"
      spacing="10" styleClass="dialog-container">

    <Label text="New Budget Envelope" styleClass="dialog-title"/>

    <Label text="Envelope Name"/>
    <TextField fx:id="nameField" promptText="e.g. Groceries May"/>

    <Label text="Category (Expense categories only)"/>
    <ChoiceBox fx:id="categoryChoice" prefWidth="260"/>

    <Label text="Period Type"/>
    <ChoiceBox fx:id="periodTypeChoice" prefWidth="180"/>

    <Label text="Period Start"/>
    <DatePicker fx:id="periodStartPicker"/>

    <Label text="Limit Amount"/>
    <TextField fx:id="limitField" promptText="e.g. 5000.00"/>

    <Label text="Alert Threshold % (e.g. 80)"/>
    <TextField fx:id="alertThresholdField" promptText="80"/>

    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancel" styleClass="btn-secondary"/>
        <Button text="Create" onAction="#onCreate"
                styleClass="btn-primary"/>
    </HBox>
</VBox>
